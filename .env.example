# =============================================================================
# DATABASE (PostgreSQL + PostGIS) — installed locally on Windows
# =============================================================================
POSTGRES_DB=busrouting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# DJANGO BACKEND
# Generate a new secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# =============================================================================
DJANGO_SECRET_KEY=generate-a-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
GOONG_API_KEY=your_goong_places_api_key_here

# =============================================================================
# GDAL / GEOS — required for GeoDjango on Windows
# Find the correct DLL paths after installing OSGeo4W or PostgreSQL's bundled GDAL.
# Common paths (adjust version to match your install):
#   PostgreSQL 18: C:/Program Files/PostgreSQL/18/bin/libgdal-35.dll
#   PostgreSQL 16: C:/Program Files/PostgreSQL/16/bin/gdal309.dll
#   OSGeo4W:       C:/OSGeo4W/bin/gdal309.dll
# Use forward slashes even on Windows.
# =============================================================================
# The DLL folder must contain libwinpthread-1.dll or loading will fail silently.
GDAL_LIBRARY_PATH=D:/MinhApp/PostgreSQL/18/bin/libgdal-35.dll
GEOS_LIBRARY_PATH=D:/MinhApp/PostgreSQL/18/bin/libgeos_c.dll

# =============================================================================
# GEOSERVER (runs in Docker)
# =============================================================================
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=your_geoserver_password_here

# =============================================================================
# FRONTEND — Vite injects VITE_* vars at build time
# =============================================================================
VITE_API_URL=http://localhost:8000/api
VITE_GEOSERVER_URL=http://localhost:8600/geoserver
VITE_GEOSERVER_WORKSPACE=busrouting
